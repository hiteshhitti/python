    "---\n",
    "## Step 5 — Proxy Basics (Concept)\n",
    "\n",
    "> Proxies route your requests through different IPs  \n",
    "> Prevents sites from blocking your real IP  \n",
    "> Free proxies are unreliable — use paid services in production\n",
    "\n",
    "**Popular proxy providers:** Bright Data, Oxylabs, SmartProxy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f3000012",
   "metadata": {},
   "outputs": [],
   "source": [
    "# How to set a proxy in Selenium (structure only — replace with real proxy)\n",
    "\n",
    "PROXY = \"host:port\"   # e.g. \"123.45.67.89:8080\"\n",
    "\n",
    "proxy_options = Options()\n",
    "proxy_options.add_argument(f\"--proxy-server={PROXY}\")\n",
    "proxy_options.add_argument(\"--headless=new\")\n",
    "\n",
    "# driver = webdriver.Chrome(options=proxy_options)\n",
    "# driver.get(\"https://api64.ipify.org\")  # Check your visible IP\n",
    "# print(driver.find_element(By.TAG_NAME, 'body').text)\n",
    "\n",
    "print(\"Proxy setup code ready — replace PROXY with a real proxy address\")\n",
    "print(\"To rotate proxies: pick random from a list on each request\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a3000013",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Proxy rotation pattern (using requests library)\n",
    "import requests\n",
    "\n",
    "PROXIES = [\n",
    "    {\"http\": \"http://proxy1:port\", \"https\": \"http://proxy1:port\"},\n",
    "    {\"http\": \"http://proxy2:port\", \"https\": \"http://proxy2:port\"},\n",
    "    {\"http\": \"http://proxy3:port\", \"https\": \"http://proxy3:port\"},\n",
    "]\n",
    "\n",
    "def fetch_with_rotating_proxy(url):\n",
    "    proxy = random.choice(PROXIES)\n",
    "    try:\n",
    "        response = requests.get(url, proxies=proxy, timeout=10)\n",
    "        return response\n",
    "    except requests.RequestException as e:\n",
    "        print(f\"Proxy failed: {e}\")\n",
    "        return None\n",
    "\n",
    "print(\"✅ Proxy rotation function ready\")\n",
    "print(\"   Replace PROXIES list with real proxy addresses\")"
   ]
  },
