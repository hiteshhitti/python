    "---\n",
    "## Step 6 — Introduction to Scrapy\n",
    "\n",
    "> Scrapy is a professional-grade scraping framework  \n",
    "> Much faster than Selenium for simple pages (async, no browser overhead)  \n",
    "> Best for: large-scale scraping, structured data pipelines\n",
    "\n",
    "```bash\n",
    "pip install scrapy\n",
    "scrapy startproject myproject\n",
    "cd myproject\n",
    "scrapy genspider quotes quotes.toscrape.com\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c3000015",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Scrapy Spider — what a spider looks like\n",
    "# This is the code you'd put in myproject/spiders/quotes.py\n",
    "\n",
    "SCRAPY_SPIDER_CODE = '''\n",
    "import scrapy\n",
    "\n",
    "class QuotesSpider(scrapy.Spider):\n",
    "    name = \"quotes\"                              # spider name\n",
    "    start_urls = [\"http://quotes.toscrape.com\"]  # starting page\n",
    "\n",
    "    def parse(self, response):\n",
    "        # CSS selectors work just like BeautifulSoup\n",
    "        for quote in response.css(\"div.quote\"):\n",
    "            yield {\n",
    "                \"text\":   quote.css(\"span.text::text\").get(),\n",
    "                \"author\": quote.css(\"small.author::text\").get(),\n",
    "                \"tags\":   quote.css(\"a.tag::text\").getall(),\n",
    "            }\n",
    "\n",
    "        # Follow the next page automatically\n",
    "        next_page = response.css(\"li.next a::attr(href)\").get()\n",
    "        if next_page:\n",
    "            yield response.follow(next_page, self.parse)\n",
    "'''\n",
    "\n",
    "print(\"Scrapy Spider code:\")\n",
    "print(SCRAPY_SPIDER_CODE)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d3000016",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Scrapy Pipeline — what a pipeline looks like\n",
    "# This goes in myproject/pipelines.py\n",
    "\n",
    "SCRAPY_PIPELINE_CODE = '''\n",
    "import csv\n",
    "\n",
    "class CsvPipeline:\n",
    "    def open_spider(self, spider):\n",
    "        self.file = open(\"quotes_scrapy.csv\", \"w\", newline=\"\", encoding=\"utf-8\")\n",
    "        self.writer = csv.DictWriter(self.file, fieldnames=[\"text\", \"author\", \"tags\"])\n",
    "        self.writer.writeheader()\n",
    "\n",
    "    def process_item(self, item, spider):\n",
    "        item[\"tags\"] = \", \".join(item[\"tags\"])  # convert list to string\n",
    "        self.writer.writerow(item)\n",
    "        return item\n",
    "\n",
    "    def close_spider(self, spider):\n",
    "        self.file.close()\n",
    "        print(\"✅ CSV saved!\")\n",
    "'''\n",
    "\n",
    "SCRAPY_SETTINGS_SNIPPET = '''\n",
    "# In settings.py — enable the pipeline:\n",
    "ITEM_PIPELINES = {\n",
    "    \"myproject.pipelines.CsvPipeline\": 300,\n",
    "}\n",
    "\n",
    "# Polite scraping settings:\n",
    "DOWNLOAD_DELAY = 1           # 1 second between requests\n",
    "RANDOMIZE_DOWNLOAD_DELAY = True  # randomize by 0.5x to 1.5x\n",
    "ROBOTSTXT_OBEY = True        # respect robots.txt\n",
    "CONCURRENT_REQUESTS = 4      # max parallel requests\n",
    "'''\n",
    "\n",
    "print(\"Pipeline code:\")\n",
    "print(SCRAPY_PIPELINE_CODE)\n",
    "print(\"Settings:\")\n",
    "print(SCRAPY_SETTINGS_SNIPPET)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e3000017",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run Scrapy from Python (instead of command line)\n",
    "# This lets you run a spider from inside a notebook\n",
    "\n",
    "try:\n",
    "    from scrapy.crawler import CrawlerProcess\n",
    "    from scrapy import Spider\n",
    "    import scrapy\n",
    "\n",
    "    class QuotesSpider(scrapy.Spider):\n",
    "        name = \"quotes_nb\"\n",
    "        start_urls = [\"http://quotes.toscrape.com\"]\n",
    "        results = []\n",
    "\n",
    "        def parse(self, response):\n",
    "            for quote in response.css(\"div.quote\"):\n",
    "                self.results.append({\n",
    "                    \"text\":   quote.css(\"span.text::text\").get(),\n",
    "                    \"author\": quote.css(\"small.author::text\").get(),\n",
    "                    \"tags\":   \", \".join(quote.css(\"a.tag::text\").getall()),\n",
    "                })\n",
    "            next_page = response.css(\"li.next a::attr(href)\").get()\n",
    "            if next_page:\n",
    "                yield response.follow(next_page, self.parse)\n",
    "\n",
    "    process = CrawlerProcess(settings={\n",
    "        \"LOG_LEVEL\": \"WARNING\",\n",
    "        \"DOWNLOAD_DELAY\": 0.5,\n",
    "    })\n",
    "    process.crawl(QuotesSpider)\n",
    "    process.start()\n",
    "\n",
    "    print(f\"✅ Scrapy scraped {len(QuotesSpider.results)} quotes\")\n",
    "    print(\"First result:\", QuotesSpider.results[0])\n",
    "\n",
    "except ImportError:\n",
    "    print(\"⚠️ Scrapy not installed. Run: pip install scrapy\")"
   ]
